# Application
APP_NAME=AssetGuard Enterprise
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-assetguard2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite:///./assetguard.db

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@assetguard.com
EMAIL_FROM_NAME=AssetGuard System

# OpenAI (for AI features)
OPENAI_API_KEY=your-openai-api-key

# Agent Secret Key
AGENT_SECRET_KEY=agent-secret-key-2024

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Admin credentials (initial setup)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123456
